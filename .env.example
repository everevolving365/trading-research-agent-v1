# Gemini AI — Required for strategy generation and asset classification
# Get a key: https://aistudio.google.com
GEMINI_API_KEY=

# Optional: pin a specific Gemini model. If unset, the agent auto-tries
# gemini-2.5-flash, gemini-2.0-flash, gemini-flash-latest in order.
# GEMINI_MODEL=gemini-2.5-flash

# Polygon.io — Required for stocks, ETFs, indices, forex (REST API key)
# Get a key: https://polygon.io/dashboard/api-keys
POLYGON_API_KEY=

# Databento — Required for futures data (paid)
# Sign up: https://databento.com
DATABENTO_API_KEY=

# --- Optional alternates (not used by current code path) ---
# Polygon S3 flat-file credentials. Path A (REST) is the active code path.
# To pivot to flat files, rewrite fetchers/polygon_fetcher.py to use boto3
# against the s3 endpoint below.
# POLYGON_S3_ACCESS_KEY_ID=
# POLYGON_S3_SECRET_ACCESS_KEY=
# POLYGON_S3_ENDPOINT=https://files.massive.com

# Binance — No key required. Public klines endpoint is used directly.
